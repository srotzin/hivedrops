{
  "name": "@hivecivilization/hivedrops-ref",
  "version": "0.0.1",
  "description": "Reference implementation of HiveDrops — Merkle-rolled metering for usage-based settlement on agent infrastructure (C13 patent claim reduced to practice).",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js",
    "./event": "./dist/event.js",
    "./merkle": "./dist/merkle.js",
    "./accumulator": "./dist/accumulator.js",
    "./challenge": "./dist/challenge.js",
    "./settle": "./dist/settle.js",
    "./anchor-stub": "./dist/anchor-stub.js"
  },
  "bin": {
    "hivedrops": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "simulate": "tsx examples/run-simulation.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "merkle",
    "metering",
    "usdc",
    "agent-infrastructure",
    "settlement",
    "hivecivilization"
  ],
  "author": "Hive Civilization",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hivecivilization/hivedrops-ref"
  }
}
